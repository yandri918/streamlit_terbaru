{
    "version": 2,
    "builds": [
        {
            "src": "api.py",
            "use": "@vercel/python"
        },
        {
            "src": "api-simulator.html",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api.py"
        },
        {
            "src": "/docs",
            "dest": "/api.py"
        },
        {
            "src": "/redoc",
            "dest": "/api.py"
        },
        {
            "src": "/openapi.json",
            "dest": "/api.py"
        },
        {
            "src": "/",
            "dest": "/api-simulator.html"
        }
    ]
}